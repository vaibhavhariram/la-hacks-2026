PORT=8000
MONGO_URI=
# MONGODB_URI is also accepted for compatibility with Person C .env files.
# MONGO_DIRECT_URI can override SRV URLs if Atlas DNS/SNI breaks local TLS.
MONGO_DIRECT_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_CONNECT_TIMEOUT_MS=4000
DB_NAME=la_hacks_2026
ROUTING_ENGINE_MODULE=routing_engine
ROUTING_ENGINE_PATH=routing_engine.py
# To enable road-following routes (OSMnx + A*), use:
# ROUTING_ENGINE_MODULE=routing_engine_osm
# ROUTING_ENGINE_PATH=routing_engine_osm.py
