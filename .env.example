# AEGIS Person C — copy this to .env and fill in real values
# NEVER commit .env to git

# NASA FIRMS — https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Agentverse — https://agentverse.ai → Settings → API Keys
AGENTVERSE_API_KEY=

# MongoDB Atlas — get URI from Person B
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aegis?retryWrites=true&w=majority

# Backend URL — stub locally (port 8001), swap to B's URL at integration
BACKEND_URL=http://localhost:8001

# Fetch.ai agent seed phrase — generates deterministic wallet address
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SEED=
