# AEGIS Person C — copy this to .env and fill in real values
# NEVER commit .env to git

# NASA FIRMS — https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# Google AI Studio — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Agentverse — https://agentverse.ai → Settings → API Keys
AGENTVERSE_API_KEY=

# MongoDB Atlas — get URI from Person B
# Backend accepts either name; keep both blank/identical in real .env if needed.
MONGO_URI=
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aegis?retryWrites=true&w=majority
# Optional Atlas DNS/SNI workaround. If set, backend uses this before MONGO_URI/MONGODB_URI.
MONGO_DIRECT_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_CONNECT_TIMEOUT_MS=4000

# Backend URL — real backend locally on port 8000; stub fallback runs on port 8001
BACKEND_URL=http://localhost:8000

# Demo data mode: auto uses real cache/API first, then committed fixtures
AEGIS_DATA_MODE=auto

# Fetch.ai agent seed phrase — generates deterministic wallet address
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_SEED=
AGENT_PORT=8002
